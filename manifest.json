{
  "manifest_version": 3,
  "name": "Gemini Wallpaper",
  "version": "1.0.0",
  "description": "Customize Google Gemini's background with your own wallpaper",
  "permissions": ["storage", "unlimitedStorage", "activeTab"],
  "host_permissions": ["https://gemini.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["katex/katex.min.js", "content.js", "pet.js", "annotations.js", "math.js", "chatbox-drag.js", "code-style.js", "linked-notes.js", "thinking-buddy.js", "bulk-delete.js", "hide-chat.js", "assistant.js"],
      "css": ["katex/katex.min.css", "content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["katex/fonts/*", "icons/assistant/*"],
      "matches": ["https://gemini.google.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
